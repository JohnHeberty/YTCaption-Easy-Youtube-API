# =========================
# Configurações da Aplicação
# =========================
APP_NAME=youtube-caption-orchestrator
APP_VERSION=2.0.0
ENVIRONMENT=development
DEBUG=false
TZ=America/Sao_Paulo

# =========================
# Servidor
# =========================
HOST=0.0.0.0
PORT=8080
WORKERS=1

# =========================
# Redis
# =========================
REDIS_URL=redis://localhost:6379/0

# =========================
# Cache e Jobs
# =========================
CACHE_TTL_HOURS=24
JOB_TIMEOUT_MINUTES=120

# =========================
# Limitações de Recursos
# =========================
MAX_FILE_SIZE_MB=2048

# =========================
# Logging
# =========================
LOG_LEVEL=INFO
LOG_DIR=./logs

# =========================
# Microserviços URLs (OBRIGATÓRIO)
# =========================
# Deve começar com http:// ou https://
VIDEO_DOWNLOADER_URL=http://localhost:8001
AUDIO_NORMALIZATION_URL=http://localhost:8002
AUDIO_TRANSCRIBER_URL=http://localhost:8003

# =========================
# Timeouts dos Microserviços (segundos)
# =========================
VIDEO_DOWNLOADER_TIMEOUT=300
AUDIO_NORMALIZATION_TIMEOUT=180
AUDIO_TRANSCRIBER_TIMEOUT=600

# Job timeouts (segundos)
VIDEO_DOWNLOADER_JOB_TIMEOUT=1800
AUDIO_NORMALIZATION_JOB_TIMEOUT=3600
AUDIO_TRANSCRIBER_JOB_TIMEOUT=2400

# =========================
# Polling Configuration
# =========================
POLL_INTERVAL_INITIAL=2.0
POLL_INTERVAL_MAX=30.0
MAX_POLL_ATTEMPTS=300

# =========================
# Retry Configuration
# =========================
MICROSERVICE_MAX_RETRIES=3
MICROSERVICE_RETRY_DELAY=2.0

# =========================
# Circuit Breaker
# =========================
CIRCUIT_BREAKER_MAX_FAILURES=10
CIRCUIT_BREAKER_RECOVERY_TIMEOUT=60
CIRCUIT_BREAKER_HALF_OPEN_MAX_REQUESTS=5

# =========================
# Orphan Job Detection
# =========================
JOB_ORPHAN_TIMEOUT_MINUTES=15
JOB_HEARTBEAT_INTERVAL_SEC=30

# =========================
# SSL Configuration
# =========================
# SSL_VERIFY: true (padrão) ou false
SSL_VERIFY=true
# SSL_CERT_PATH: Caminho para certificado customizado (opcional)
# SSL_CERT_PATH=/path/to/cert.pem

# =========================
# Parâmetros Padrão dos Microserviços
# =========================
DEFAULT_LANGUAGE=auto
DEFAULT_REMOVE_NOISE=true
DEFAULT_CONVERT_MONO=true
DEFAULT_HIGHPASS_FILTER=false
DEFAULT_SAMPLE_RATE_16K=true
