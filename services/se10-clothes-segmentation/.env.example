# ===== APLICACAO =====
APP_NAME=SE10 Clothes Segmentation
VERSION=1.0.0
ENVIRONMENT=development
DEBUG=false
TZ=America/Sao_Paulo

# ===== SERVIDOR =====
HOST=0.0.0.0
DIVISOR=10
PORT=8010
WORKERS=1

# ===== REDIS =====
REDIS_URL=redis://localhost:6379/10

# ===== MODELO ML =====
DEVICE=auto
CHECKPOINT_DIR=./checkpoints
EXTERNAL_DIR=./external
BOX_THRESHOLD=0.10
TEXT_THRESHOLD=0.10
MAX_AREA_PCT=0.29
MAX_OBJECTS=50
WORKER_THREADS=2

# ===== SE10 AUTH =====
SE10_API_KEY=your-api-key-here

# ===== STORAGE =====
OUTPUT_DIR=./data/outputs
TEMP_DIR=./data/temp

# ===== LOGGING =====
LOG_LEVEL=INFO
