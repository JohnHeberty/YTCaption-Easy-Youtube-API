# ===== APLICAÇÃO =====
APP_NAME=SE9 Image Engine
VERSION=1.0.0
ENVIRONMENT=development
DEBUG=false
TZ=America/Sao_Paulo

# ===== SERVIDOR =====
HOST=0.0.0.0
PORT=8009
WORKERS=1

# ===== GPU =====
GPU_MODE=lazy
# GPU_DEVICE_ID=0
# MAX_VRAM_MB=0
MODEL_IDLE_TIMEOUT=300

# ===== REDIS =====
REDIS_URL=redis://localhost:6379/9

# ===== CELERY =====
CELERY_BROKER_URL=redis://localhost:6379/9
CELERY_RESULT_BACKEND=redis://localhost:6379/9

# ===== SE9 AUTH =====
SE9_API_KEY=se9-test-key-2026

# ===== GERACAO DE IMAGEM =====
DEFAULT_PERFORMANCE=Speed
DEFAULT_CFG_SCALE=4.0
DEFAULT_SHARPNESS=2.0
DEFAULT_WIDTH=1024
DEFAULT_HEIGHT=1024

# ===== STORAGE =====
OUTPUT_DIR=./data/outputs
MODEL_DIR=./data/models
TEMP_DIR=./data/temp

# ===== LOGGING =====
LOG_LEVEL=INFO
