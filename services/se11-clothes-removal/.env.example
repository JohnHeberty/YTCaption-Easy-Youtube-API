# Identity
APP_NAME=Clothes Removal
VERSION=1.0.0
ENVIRONMENT=development
DEBUG=false
TZ=America/Sao_Paulo

# Server
HOST=0.0.0.0
DIVISOR=11
PORT=8011
WORKERS=1

# Redis
REDIS_URL=redis://192.168.1.110:6379/11

# Authentication
API_KEY=se11-test-key-2026

# Logging
LOG_DIR=./data/logs
LOG_LEVEL=INFO

# Output
OUTPUT_DIR=./data/outputs
MAX_FILE_SIZE_MB=50

# SE10 (Clothes Segmentation)
SE10_URL=http://localhost:8010
SE10_API_KEY=se10-test-key-2026
SE10_TIMEOUT=60

# SE8 (Image Generation / Inpainting)
SE8_URL=http://localhost:8008
SE8_API_KEY=se8-test-key-2026
SE8_TIMEOUT=300

# Inpainting defaults
DEFAULT_PROMPT=nude, naked body, smooth skin
DEFAULT_NEGATIVE_PROMPT=clothes, clothing, fabric, wrinkles, folds
DEFAULT_INPAINT_STRENGTH=1.0
DEFAULT_BOX_THRESHOLD=0.10
DEFAULT_TEXT_THRESHOLD=0.10

# Worker
MAX_CONCURRENT_JOBS=2
